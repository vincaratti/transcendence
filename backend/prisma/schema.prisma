generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model Message {
  id          String    @id @default(uuid())
  sender      User      @relation("MessageSender", fields: [senderId], references: [id])
  receiver    User?      @relation("messageReceiver", fields: [recipientId], references:[id])
  senderId    String    @map("sender_id")
  recipientId String?   @map("recipient_id")
  content     String
  createdAt   DateTime  @default(now()) @map("created_at")
  readAt      DateTime? @map("read_at")

  @@map("messages")
}
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  players   Player[]
  messagesSent Message[] @relation("MessageSender")
  messagesReceived    Message[] @relation("messageReceiver")
  blocksGiven         Block[]      @relation("Blocker") 
  blocksReceived      Block[]      @relation("Blocked")
  friendshipsSent     Friendship[] @relation("FriendshipRequester")
  friendshipsReceived Friendship[] @relation("FriendshipAddressee")

  @@map("users")
}

model Game {
  id             String     @id @default(uuid())
  code           String     @unique
  status         GameStatus @default(WAITING)
  currentTeam    Team       @default(RED) @map("current_team")
  phase          Phase      @default(CLUE)
  remainingGuess Int        @default(0) @map("remaining_guess")
  currentClue    String?    @map("current_clue")
  winner         Team?
  board          Json
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  players        Player[]

  @@map("games")
}
model Player {
  id     String     @id @default(uuid())
  team   Team
  role   PlayerRole
  user   User       @relation(fields: [userId], references: [id])
  userId String     @map("user_id")
  game   Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId String     @map("game_id")

  @@unique([userId, gameId])
  @@map("players")
}
model Block {
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockerId String   @map("blocker_id")
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@id([blockerId, blockedId])   // ← this is how you do composite primary key in Prisma
  @@map("blocks")
}

model Friendship {
  id          String           @id @default(uuid())
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String           @map("requester_id")
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum Team {
  RED
  BLUE
}

enum Phase {
  CLUE
  GUESS
}

enum PlayerRole {
  SPYMASTER
  OPERATIVE
}
