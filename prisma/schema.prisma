generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  players   Player[]

  friendshipsSent     Friendship[] @relation("FriendshipRequester")
  friendshipsReceived Friendship[] @relation("FriendshipAddressee")

  @@map("users")
}

model Game {
  id             String     @id @default(uuid())
  code           String     @unique
  status         GameStatus @default(WAITING)
  currentTeam    Team       @default(RED) @map("current_team")
  phase          Phase      @default(CLUE)
  remainingGuess Int        @default(0) @map("remaining_guess")
  currentClue    String?    @map("current_clue")
  winner         Team?
  board          Json
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  players        Player[]

  @@map("games")
}

model Player {
  id     String     @id @default(uuid())
  team   Team
  role   PlayerRole
  user   User       @relation(fields: [userId], references: [id])
  userId String     @map("user_id")
  game   Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId String     @map("game_id")

  @@unique([userId, gameId])
  @@map("players")
}

model Friendship {
  id          String           @id @default(uuid())
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String           @map("requester_id")
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

model Achievement {
  id          String   @id @default(uuid())
  name        String
  description String
  icon        String?
  condition   String
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @map("user_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum Team {
  RED
  BLUE
}

enum Phase {
  CLUE
  GUESS
}

enum PlayerRole {
  SPYMASTER
  OPERATIVE
}
